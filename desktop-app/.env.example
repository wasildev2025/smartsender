# Build-time configuration for the desktop app.
#
# These are read by vite.config.ts and baked into the main-process bundle. A
# packaged binary does NOT inherit env vars at runtime, so they must be set
# in the shell that runs `npm run release`.
#
# In dev (`npm run dev`) the build falls back to a known dev key so the app
# still boots; the runtime guard refuses to start a packaged binary that
# shipped that placeholder.

# Backend origin used for license verification.
SS_API_URL="https://smartsender.vercel.app"

# Ed25519 PUBLIC key matching backend's SS_LICENSE_PRIVATE_KEY.
# Must be PEM-encoded; literal newlines or escaped \n both work.
SS_LICENSE_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# Set to 1 to force release-build semantics (vite.config.ts will refuse to
# build with the placeholder key). The release npm script sets this for you.
SS_RELEASE=0
