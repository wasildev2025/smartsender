{
  "name": "desktop-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "release": "npm run build && electron-builder --win -c.npmRebuild=false"
  },
  "dependencies": {
    "bufferutil": "^4.1.0",
    "clsx": "^2.1.1",
    "jose": "^6.2.2",
    "keytar": "^7.9.0",
    "lucide-react": "^1.8.0",
    "node-machine-id": "^1.1.12",
    "papaparse": "^5.5.3",
    "qrcode": "^1.5.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.1",
    "tailwind-merge": "^3.5.0",
    "utf-8-validate": "^6.0.6",
    "whatsapp-web.js": "^1.34.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@electron/fuses": "^2.1.1",
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.2",
    "@types/papaparse": "^5.5.2",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.19",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^6.4.2",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.6",
    "wait-on": "^9.0.5"
  },
  "build": {
    "appId": "com.smartsender.app",
    "productName": "Smart Sender",
    "directories": {
      "output": "release"
    },
    "asar": true,
    "afterPack": "./electron/fuses.config.cjs",
    "publish": [
      {
        "provider": "generic",
        "url": "https://updates.smartsender.app/"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "signtoolOptions": {
        "signingHashAlgorithms": [
          "sha256"
        ],
        "rfc3161TimeStampServer": "http://timestamp.digicert.com",
        "publisherName": "Smart Sender"
      }
    },
    "mac": {
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "./electron/entitlements.mac.plist",
      "entitlementsInherit": "./electron/entitlements.mac.plist",
      "notarize": true
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
